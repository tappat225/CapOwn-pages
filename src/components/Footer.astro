---
import { ExternalLink } from '@lucide/astro';
import type { Lang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t(lang);
const docsUrl = lang === 'zh' ? 'https://docs.capown.net/zh/' : 'https://docs.capown.net/';
---

<footer class="site-footer">
  <div class="footer-inner section-shell">
    <div class="footer-brand">
      <div><img src="/capown-logo.png" alt="" width="34" height="34" /><strong>CapOwn</strong></div>
      <p>{i.footer.tagline}</p>
    </div>
    <nav aria-label="Footer">
      <a href={docsUrl} target="_blank" rel="noreferrer">{i.footer.docs}<ExternalLink aria-hidden="true" /></a>
      <a href="https://github.com/tappat225/CapOwn" target="_blank" rel="noreferrer">{i.footer.github}<ExternalLink aria-hidden="true" /></a>
      <a href="https://gitee.com/TappaT/CapOwn" target="_blank" rel="noreferrer">{i.footer.gitee}<ExternalLink aria-hidden="true" /></a>
    </nav>
    <p class="license">{i.footer.license}</p>
  </div>
</footer>

<style>
  .site-footer { padding: 3rem 0; border-top: 1px solid var(--line); background: #090c0f; }
  .footer-inner { display: grid; grid-template-columns: 1.2fr auto auto; align-items: end; gap: 3rem; }
  .footer-brand > div { display: flex; align-items: center; gap: 0.65rem; }
  .footer-brand img { width: 1.8rem; height: 1.8rem; object-fit: contain; }
  .footer-brand strong { font-size: 0.95rem; }
  .footer-brand p, .license { margin: 0.7rem 0 0; color: var(--quiet); font-size: 0.72rem; }
  nav { display: flex; gap: 1.4rem; }
  nav a { display: inline-flex; align-items: center; gap: 0.35rem; color: var(--muted); font-size: 0.76rem; }
  nav a:hover { color: var(--white); }
  nav svg { width: 0.7rem; height: 0.7rem; }
  .license { margin: 0; font-family: var(--font-mono); font-size: 0.62rem; }
  @media (max-width: 780px) { .footer-inner { grid-template-columns: 1fr; align-items: start; gap: 1.6rem; } }
  @media (max-width: 420px) { nav { flex-direction: column; gap: 0.8rem; } }
</style>
