---
import type { Lang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
---

<section class="flow" id="flow">
  <div class="section-kicker">{i.flow.kicker}</div>
  <div class="flow-steps">
    {i.flow.steps.map((step) => (
      <div class="flow-step">
        <span class="step-num">{step.num}</span>
        <strong>{step.title}</strong>
        <p>{step.description}</p>
      </div>
    ))}
  </div>
  <div class="flow-line" aria-hidden="true">
    <span></span>
    <span></span>
  </div>
</section>

<style>
  .flow {
    width: min(1120px, calc(100% - 3rem));
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 7rem) 0;
    position: relative;
  }

  .section-kicker {
    margin-bottom: 2.5rem;
    color: var(--mint);
    font-size: 0.68rem;
    font-weight: 820;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    text-align: center;
  }

  .flow-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    position: relative;
  }

  .flow-step {
    padding: 2rem 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.015);
  }

  .step-num {
    display: block;
    margin-bottom: 2rem;
    color: var(--quiet);
    font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
    font-size: 0.72rem;
  }

  .flow-step strong {
    display: block;
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 860;
    color: var(--white);
  }

  .flow-step p {
    margin: 0.6rem 0 0;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .flow-line {
    display: flex;
    justify-content: space-around;
    padding: 0 15%;
    margin-top: -1px;
    pointer-events: none;
  }

  .flow-line span {
    display: block;
    width: 2rem;
    height: 2rem;
    position: relative;
  }

  .flow-line span::after {
    content: '→';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--mint);
    font-size: 1.2rem;
    opacity: 0.5;
  }

  @media (max-width: 820px) {
    .flow-steps {
      grid-template-columns: 1fr;
    }

    .flow-line { display: none; }

    .step-num { margin-bottom: 1rem; }
  }
</style>
