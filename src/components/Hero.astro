---
import { ArrowRight, BookOpen, GitFork } from '@lucide/astro';
import type { Lang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang: Lang; }

const { lang } = Astro.props;
const i = t(lang);
const docsUrl = lang === 'zh' ? 'https://docs.capown.net/zh/' : 'https://docs.capown.net/';
---

<section class="hero" aria-labelledby="hero-title">
  <img class="hero-image" src="/capown-relay-hero.png" alt="" width="1780" height="883" fetchpriority="high" />
  <div class="hero-shade" aria-hidden="true"></div>
  <div class="hero-content section-shell">
    <div class="hero-copy">
      <p class="hero-kicker"><span></span>{i.hero.eyebrow}</p>
      <h1 id="hero-title">{i.hero.title}</h1>
      <p class="hero-description">{i.hero.description}</p>
      <div class="hero-actions">
        <a class="button-link primary" href={docsUrl} target="_blank" rel="noreferrer">
          <BookOpen aria-hidden="true" /> {i.hero.cta_docs} <ArrowRight aria-hidden="true" />
        </a>
        <a class="button-link secondary" href="https://github.com/tappat225/CapOwn" target="_blank" rel="noreferrer">
          <GitFork aria-hidden="true" /> {i.hero.cta_github}
        </a>
      </div>
      <p class="gitee-link">
        {i.hero.gitee_prefix}
        <a href="https://gitee.com/TappaT/CapOwn" target="_blank" rel="noreferrer">{i.hero.cta_gitee} <ArrowRight aria-hidden="true" /></a>
      </p>
    </div>

    <div class="proof-strip" aria-label="Product highlights">
      {i.proof.map((item) => (
        <div class="proof-item">
          <strong>{item.value}</strong>
          <span>{item.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero { position: relative; min-height: 96svh; overflow: hidden; isolation: isolate; background: #06090c; }
  .hero-image { position: absolute; inset: 0; z-index: -3; width: 100%; height: 100%; object-fit: cover; object-position: 57% center; }
  .hero-shade { position: absolute; inset: 0; z-index: -2; background: linear-gradient(90deg, rgba(4,7,9,0.98) 0%, rgba(4,7,9,0.91) 29%, rgba(4,7,9,0.28) 62%, rgba(4,7,9,0.1) 100%), linear-gradient(0deg, rgba(7,10,13,0.96) 0%, transparent 24%, rgba(7,10,13,0.28) 100%); }
  .hero-content { display: flex; min-height: 96svh; flex-direction: column; justify-content: center; padding-top: 7.5rem; padding-bottom: 1.4rem; }
  .hero-copy { width: min(690px, 58%); margin-block: auto; padding: 3rem 0 4rem; }
  .hero-kicker { display: flex; align-items: center; gap: 0.65rem; margin: 0 0 1.25rem; color: var(--mint); font-family: var(--font-mono); font-size: 0.76rem; font-weight: 600; }
  .hero-kicker span { width: 1.8rem; height: 1px; background: currentColor; }
  h1 { margin: 0; max-width: 680px; font-size: clamp(3rem, 6.3vw, 5.35rem); font-weight: 690; line-height: 1.04; letter-spacing: 0; text-wrap: balance; }
  .hero-description { max-width: 620px; margin: 1.55rem 0 0; color: #c3cad2; font-size: clamp(1.05rem, 1.55vw, 1.23rem); line-height: 1.75; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 2.1rem; }
  .gitee-link { display: flex; flex-wrap: wrap; gap: 0.42rem; margin: 1rem 0 0; color: var(--quiet); font-size: 0.78rem; }
  .gitee-link a { display: inline-flex; align-items: center; gap: 0.25rem; color: #b8c0c9; }
  .gitee-link a:hover { color: var(--white); }
  .gitee-link svg { width: 0.75rem; height: 0.75rem; }
  .proof-strip { display: grid; grid-template-columns: repeat(3, 1fr); width: min(780px, 78%); border-top: 1px solid rgba(255,255,255,0.15); }
  .proof-item { display: flex; min-height: 4.7rem; flex-direction: column; justify-content: center; gap: 0.3rem; padding: 0.9rem 1.1rem; border-right: 1px solid rgba(255,255,255,0.12); }
  .proof-item:first-child { padding-left: 0; }
  .proof-item:last-child { border-right: 0; }
  .proof-item strong { font-family: var(--font-mono); font-size: 0.86rem; font-weight: 620; color: var(--white); }
  .proof-item span { color: #8e98a3; font-size: 0.72rem; line-height: 1.4; }
  @media (max-width: 900px) {
    .hero-image { object-position: 66% center; opacity: 0.74; }
    .hero-shade { background: linear-gradient(90deg, rgba(4,7,9,0.98) 0%, rgba(4,7,9,0.9) 50%, rgba(4,7,9,0.28) 100%), linear-gradient(0deg, rgba(7,10,13,0.96) 0%, transparent 35%); }
    .hero-copy { width: min(650px, 78%); }
    .proof-strip { width: 100%; }
  }
  @media (max-height: 780px) and (min-width: 641px) {
    .hero, .hero-content { min-height: calc(100svh - 24px); }
    .hero-content { padding-top: 5rem; padding-bottom: 0.5rem; }
    .hero-copy { margin-block: auto; padding: 1rem 0 1.2rem; }
    h1 { font-size: clamp(3.35rem, 5vw, 4.15rem); line-height: 1.02; }
    .hero-description { margin-top: 0.9rem; font-size: 1rem; line-height: 1.55; }
    .hero-actions { margin-top: 1.2rem; }
    .gitee-link { margin-top: 0.65rem; }
    .proof-item { min-height: 3.6rem; padding-block: 0.5rem; }
  }
  @media (max-width: 640px) {
    .hero { min-height: calc(100svh - 24px); }
    .hero-image { object-position: 68% center; opacity: 0.48; }
    .hero-shade { background: linear-gradient(180deg, rgba(4,7,9,0.35) 0%, rgba(4,7,9,0.9) 40%, #070a0d 84%); }
    .hero-content { min-height: calc(100svh - 24px); padding-top: 6rem; padding-bottom: 0.7rem; }
    .hero-copy { width: 100%; padding: 4.5rem 0 2.2rem; }
    h1 { font-size: clamp(2.55rem, 12vw, 3.7rem); }
    .hero-description { font-size: 1rem; line-height: 1.65; }
    .hero-actions { flex-direction: column; }
    .hero-actions .button-link { width: 100%; }
    .proof-strip { grid-template-columns: repeat(3, 1fr); }
    .proof-item, .proof-item:first-child { min-height: 5.2rem; padding: 0.75rem 0.55rem; border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 0; }
    .proof-item:first-child { padding-left: 0; }
    .proof-item:last-child { padding-right: 0; border-right: 0; }
    .proof-item strong { font-size: 0.7rem; }
    .proof-item span { font-size: 0.59rem; }
  }
</style>
