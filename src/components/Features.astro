---
import { Binoculars, Files, ListChecks } from '@lucide/astro';
import type { Lang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t(lang);
const icons = [Binoculars, Files, ListChecks];
---

<section class="capabilities" id="capabilities" aria-labelledby="capabilities-title">
  <div class="section-shell">
    <div class="section-heading">
      <p class="section-kicker">{i.capabilities.kicker}</p>
      <h2 class="section-title" id="capabilities-title">{i.capabilities.title}</h2>
      <p class="section-description">{i.capabilities.description}</p>
    </div>
    <div class="capability-grid">
      {i.capabilities.groups.map((group, index) => {
        const Icon = icons[index];
        return (
          <article class="capability-group">
            <div class="group-icon"><Icon aria-hidden="true" /></div>
            <p class="group-eyebrow">{group.eyebrow}</p>
            <h3>{group.title}</h3>
            <p>{group.description}</p>
            <div class="tool-list">
              {group.items.map((item) => <code>{item}</code>)}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .capabilities { padding: clamp(5rem, 9vw, 9rem) 0; background: var(--ink); }
  .capability-grid { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .capability-group { min-width: 0; padding: 2rem clamp(1.2rem, 2.6vw, 2.4rem) 2.5rem; border-right: 1px solid var(--line); }
  .capability-group:first-child { padding-left: 0; }
  .capability-group:last-child { padding-right: 0; border-right: 0; }
  .group-icon { display: grid; width: 2.55rem; height: 2.55rem; place-items: center; margin-bottom: 2.6rem; border: 1px solid rgba(112,214,163,0.3); border-radius: 5px; color: var(--mint); }
  .group-icon svg { width: 1.2rem; height: 1.2rem; }
  .group-eyebrow { margin: 0 0 0.65rem !important; color: var(--mint) !important; font-family: var(--font-mono); font-size: 0.68rem !important; text-transform: uppercase; }
  h3 { margin: 0; font-size: clamp(1.35rem, 2vw, 1.75rem); font-weight: 640; line-height: 1.25; }
  .capability-group > p { margin: 0.85rem 0 0; color: var(--muted); font-size: 0.9rem; line-height: 1.72; }
  .tool-list { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 2rem; }
  .tool-list code { padding: 0.4rem 0.58rem; border: 1px solid var(--line); border-radius: 4px; background: var(--surface); color: #aeb8c1; font-family: var(--font-mono); font-size: 0.65rem; }
  @media (max-width: 820px) {
    .capability-grid { grid-template-columns: 1fr; }
    .capability-group, .capability-group:first-child, .capability-group:last-child { padding: 2rem 0; border-right: 0; border-bottom: 1px solid var(--line); }
    .capability-group:last-child { border-bottom: 0; }
    .group-icon { margin-bottom: 1.5rem; }
  }
</style>
