---
import type { Lang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero-gradient" aria-hidden="true"></div>

  <svg class="network-paths" aria-hidden="true" viewBox="0 0 1440 820" preserveAspectRatio="xMidYMid slice">
    <defs>
      <filter id="network-glow" x="-40%" y="-40%" width="180%" height="180%">
        <feGaussianBlur stdDeviation="4" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <linearGradient id="network-flow" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#5ed29c" stop-opacity="0" />
        <stop offset="34%" stop-color="#58e6ff" stop-opacity="0.92" />
        <stop offset="62%" stop-color="#5ed29c" stop-opacity="1" />
        <stop offset="100%" stop-color="#7c5cff" stop-opacity="0" />
      </linearGradient>
    </defs>

    <g class="network-lines">
      <path class="network-backbone" d="M260 510C405 506 500 460 626 430" />
      <path class="network-flowline" style="--delay: -0.2s; --duration: 7.2s" d="M260 510C405 506 500 460 626 430" />
      <path class="network-backbone" d="M626 430C770 294 925 180 1144 160" />
      <path class="network-flowline" style="--delay: -1.4s; --duration: 8.4s" d="M626 430C770 294 925 180 1144 160" />
      <path class="network-backbone" d="M626 430C805 404 955 374 1218 370" />
      <path class="network-flowline" style="--delay: -2.1s; --duration: 7.8s" d="M626 430C805 404 955 374 1218 370" />
      <path class="network-backbone" d="M626 430C780 520 948 612 1228 586" />
      <path class="network-flowline" style="--delay: -3s; --duration: 8.8s" d="M626 430C780 520 948 612 1228 586" />
      <path class="network-backbone" d="M626 430C742 650 930 716 1128 700" />
      <path class="network-flowline" style="--delay: -0.9s; --duration: 9.2s" d="M626 430C742 650 930 716 1128 700" />
      <path class="network-backbone network-secondary" d="M380 585C505 545 565 498 626 430" />
      <path class="network-flowline network-secondary-flow" style="--delay: -4.2s; --duration: 10s" d="M380 585C505 545 565 498 626 430" />
    </g>

    <g class="network-nodes">
      <circle class="node-halo node-master" cx="626" cy="430" r="44" />
      <circle class="node-core" cx="626" cy="430" r="8" />
      <circle class="node-halo" cx="260" cy="510" r="28" />
      <circle class="node-core" cx="260" cy="510" r="5" />
      <circle class="node-halo" cx="1144" cy="160" r="24" />
      <circle class="node-core" cx="1144" cy="160" r="5" />
      <circle class="node-halo" cx="1218" cy="370" r="24" />
      <circle class="node-core" cx="1218" cy="370" r="5" />
      <circle class="node-halo" cx="1228" cy="586" r="24" />
      <circle class="node-core" cx="1228" cy="586" r="5" />
      <circle class="node-halo" cx="1128" cy="700" r="24" />
      <circle class="node-core" cx="1128" cy="700" r="5" />
    </g>
  </svg>

  <div class="hero-content">
    <p class="eyebrow reveal">{i.hero.eyebrow}</p>
    <h1 class="reveal" id="hero-title" style="animation-delay: 0.15s">
      {i.hero.title1}<br />{i.hero.title2}
    </h1>
    <p class="hero-copy reveal" style="animation-delay: 0.3s">{i.hero.description}</p>
    <div class="hero-actions reveal" style="animation-delay: 0.45s">
      <a class="primary-action" href="https://dashboard.capown.net" target="_blank" rel="noreferrer">
        {i.hero.cta_dashboard}
        <span aria-hidden="true">&rarr;</span>
      </a>
      <a class="secondary-action" href="https://github.com/tappat225/CapOwn" target="_blank" rel="noreferrer">
        {i.hero.cta_github}
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100svh;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(ellipse 60% 50% at 50% 45%, rgba(29, 95, 73, 0.25) 0%, transparent 70%),
      radial-gradient(ellipse 30% 28% at 50% 42%, rgba(45, 212, 191, 0.12) 0%, transparent 60%);
  }

  .network-paths {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    opacity: 0.7;
    mix-blend-mode: screen;
  }

  .network-backbone, .network-flowline {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .network-backbone {
    stroke: rgba(88, 230, 255, 0.1);
    stroke-width: 1.2;
    filter: url("#network-glow");
  }

  .network-secondary { stroke: rgba(94, 210, 156, 0.07); }

  .network-flowline {
    stroke: url("#network-flow");
    stroke-width: 2.8;
    stroke-dasharray: 34 98;
    stroke-dashoffset: 0;
    opacity: 0.78;
    filter: url("#network-glow");
    animation: signal-flow var(--duration, 8s) linear infinite;
    animation-delay: var(--delay, 0s);
  }

  .network-secondary-flow {
    stroke-width: 1.8;
    opacity: 0.44;
  }

  .node-halo, .node-core {
    transform-box: fill-box;
    transform-origin: center;
  }

  .node-halo {
    fill: rgba(88, 230, 255, 0.07);
    stroke: rgba(88, 230, 255, 0.28);
    stroke-width: 1;
    filter: url("#network-glow");
    animation: node-pulse 3.8s ease-in-out infinite;
  }

  .node-core { fill: var(--mint); filter: url("#network-glow"); }
  .node-master { animation-duration: 2.8s; }

  .hero-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: min(72rem, 100%);
    padding: 9rem 1.5rem 7.5rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--mint);
    font-size: clamp(0.8rem, 1.2vw, 1rem);
    font-weight: 820;
    letter-spacing: 0.32em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 62rem;
    margin: 1.1rem 0 0;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900;
    line-height: 1.01;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .hero-copy {
    max-width: 38rem;
    margin: 1.5rem auto 0;
    color: var(--muted);
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
    margin-top: 2.3rem;
  }

  .primary-action, .secondary-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.25rem;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    transition: background 220ms ease, box-shadow 220ms ease, color 220ms ease, transform 220ms ease, border-color 220ms ease;
  }

  .primary-action {
    gap: 0.65rem;
    padding: 0 1.8rem;
    background: var(--mint);
    color: var(--ink);
  }

  .primary-action:hover {
    background: #79e0ae;
    box-shadow: 0 0 36px rgba(94, 210, 156, 0.45);
    transform: translateY(-2px);
  }

  .secondary-action {
    padding: 0 1.55rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: rgba(255, 255, 255, 0.82);
  }

  .secondary-action:hover {
    border-color: rgba(94, 210, 156, 0.48);
    color: var(--mint);
    transform: translateY(-2px);
  }

  @media (max-width: 820px) {
    .network-paths {
      opacity: 0.45;
      transform: scale(1.2);
      transform-origin: 58% 48%;
    }

    .hero-content {
      padding: 7.5rem 1.25rem 4.5rem;
    }

    h1 { font-size: clamp(2.75rem, 14vw, 4.8rem); }
  }

  @media (max-width: 520px) {
    .hero-content {
      align-items: flex-start;
      text-align: left;
    }

    .hero-actions {
      width: 100%;
      justify-content: flex-start;
    }

    .primary-action, .secondary-action { width: 100%; }
  }
</style>
