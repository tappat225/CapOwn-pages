---
import type { Lang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);

const icons = [
  // Outbound-only: arrow going out
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>`,
  // Network-friendly: globe
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  // Agent-ready: terminal
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
  // Minimal trust: shield
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  // Host or container: box
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`,
  // Multi-user: users
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
];
---

<section class="features" id="features">
  <div class="section-kicker">{i.features.kicker}</div>
  <div class="features-grid">
    {i.features.items.map((item, idx) => (
      <div class="feature-card">
        <div class="feature-icon" set:html={icons[idx]} />
        <strong>{item.title}</strong>
        <p>{item.description}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .features {
    width: min(1120px, calc(100% - 3rem));
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 7rem) 0;
  }

  .section-kicker {
    margin-bottom: 2.5rem;
    color: var(--mint);
    font-size: clamp(0.8rem, 1.2vw, 1rem);
    font-weight: 820;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    text-align: center;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
  }

  .feature-card {
    padding: 2rem 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: linear-gradient(145deg, rgba(94, 210, 156, 0.04), transparent 50%);
    transition: background 250ms ease;
  }

  .feature-card:hover {
    background: linear-gradient(145deg, rgba(94, 210, 156, 0.1), rgba(88, 230, 255, 0.03) 50%, transparent);
  }

  .feature-icon {
    width: 1.6rem;
    height: 1.6rem;
    margin-bottom: 1.2rem;
    color: var(--mint);
  }

  .feature-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .feature-card strong {
    display: block;
    font-size: 1.05rem;
    font-weight: 720;
    margin-bottom: 0.4rem;
  }

  .feature-card p {
    margin: 0;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  @media (max-width: 820px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
