---
import { ArrowDown, Bot, Router, Server } from '@lucide/astro';
import type { Lang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t(lang);
const icons = [Bot, Router, Server];
---

<section class="flow" id="how" aria-labelledby="flow-title">
  <div class="section-shell">
    <div class="section-heading">
      <p class="section-kicker">{i.flow.kicker}</p>
      <h2 class="section-title" id="flow-title">{i.flow.title}</h2>
      <p class="section-description">{i.flow.description}</p>
    </div>
    <div class="flow-grid">
      {i.flow.steps.map((step, index) => {
        const Icon = icons[index];
        return (
          <div class="flow-step">
            <div class="step-top"><span>{step.num}</span><Icon aria-hidden="true" /></div>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
            {index < i.flow.steps.length - 1 && <ArrowDown class="step-arrow" aria-hidden="true" />}
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .flow { padding: clamp(5rem, 9vw, 8.5rem) 0; background: #12171c; }
  .flow-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(2rem, 5vw, 5rem); }
  .flow-step { position: relative; min-width: 0; }
  .step-top { display: flex; align-items: center; justify-content: space-between; padding-bottom: 1rem; border-bottom: 1px solid var(--line-strong); }
  .step-top span { color: var(--quiet); font-family: var(--font-mono); font-size: 0.7rem; }
  .step-top svg { width: 1.3rem; height: 1.3rem; color: var(--mint); }
  h3 { margin: 1.65rem 0 0; font-size: clamp(1.35rem, 2vw, 1.75rem); font-weight: 630; }
  .flow-step p { margin: 0.8rem 0 0; color: var(--muted); font-size: 0.9rem; line-height: 1.75; }
  .step-arrow { display: none; }
  @media (max-width: 760px) {
    .flow-grid { grid-template-columns: 1fr; gap: 3rem; }
    .step-arrow { display: block; position: absolute; left: 0.15rem; bottom: -2rem; width: 1rem; height: 1rem; color: var(--quiet); }
  }
</style>
