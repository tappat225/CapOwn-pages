---
import { BookOpen, GitFork, Menu, X } from '@lucide/astro';
import type { Lang } from '../i18n/index';
import { t, getOtherLang } from '../i18n/index';

interface Props { lang: Lang; }

const { lang } = Astro.props;
const i = t(lang);
const otherLang = getOtherLang(lang);
const base = import.meta.env.BASE_URL;
const docsUrl = lang === 'zh' ? 'https://docs.capown.net/zh/' : 'https://docs.capown.net/';
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href={`${base}${lang}/`} aria-label="CapOwn home">
      <img src={`${base}capown-logo.png`} alt="" width="34" height="34" />
      <span>CapOwn</span>
    </a>

    <nav class="desktop-nav" aria-label="Main">
      <a href={`${base}${lang}/#capabilities`}>{i.nav.capabilities}</a>
      <a href={`${base}${lang}/#how`}>{i.nav.flow}</a>
      <a href={`${base}${lang}/#security`}>{i.nav.security}</a>
    </nav>

    <div class="desktop-actions">
      <a class="utility-link" href={docsUrl} target="_blank" rel="noreferrer">
        <BookOpen aria-hidden="true" /> {i.nav.docs}
      </a>
      <a class="icon-link" href="https://github.com/tappat225/CapOwn" target="_blank" rel="noreferrer" aria-label="GitHub">
        <GitFork aria-hidden="true" />
      </a>
      <a class="lang-switch" href={`${base}${otherLang}/`}>{i.lang_switch}</a>
    </div>

    <div class="mobile-actions">
      <a class="lang-switch" href={`${base}${otherLang}/`}>{i.lang_switch}</a>
      <button class="menu-button" type="button" aria-label="Open menu" aria-expanded="false" data-menu-open>
        <Menu aria-hidden="true" />
      </button>
    </div>
  </div>
</header>

<div class="mobile-menu" aria-hidden="true" data-menu>
  <div class="mobile-menu-head">
    <a class="brand" href={`${base}${lang}/`} data-menu-link>
      <img src={`${base}capown-logo.png`} alt="" width="34" height="34" />
      <span>CapOwn</span>
    </a>
    <button class="menu-button" type="button" aria-label="Close menu" data-menu-close><X aria-hidden="true" /></button>
  </div>
  <nav>
    <a href={`${base}${lang}/#capabilities`} data-menu-link>{i.nav.capabilities}</a>
    <a href={`${base}${lang}/#how`} data-menu-link>{i.nav.flow}</a>
    <a href={`${base}${lang}/#security`} data-menu-link>{i.nav.security}</a>
    <a href={docsUrl} target="_blank" rel="noreferrer" data-menu-link>{i.nav.docs}</a>
    <a href="https://github.com/tappat225/CapOwn" target="_blank" rel="noreferrer" data-menu-link>GitHub</a>
    <a href="https://gitee.com/TappaT/CapOwn" target="_blank" rel="noreferrer" data-menu-link>Gitee</a>
  </nav>
</div>

<script>
  const menu = document.querySelector('[data-menu]');
  const openButton = document.querySelector('[data-menu-open]');
  const closeButton = document.querySelector('[data-menu-close]');
  const menuLinks = document.querySelectorAll('[data-menu-link]');

  function setMenu(open: boolean) {
    menu?.classList.toggle('is-open', open);
    document.body.classList.toggle('menu-open', open);
    menu?.setAttribute('aria-hidden', String(!open));
    openButton?.setAttribute('aria-expanded', String(open));
  }

  openButton?.addEventListener('click', () => setMenu(true));
  closeButton?.addEventListener('click', () => setMenu(false));
  menuLinks.forEach((link) => link.addEventListener('click', () => setMenu(false)));
  document.addEventListener('keydown', (event) => { if (event.key === 'Escape') setMenu(false); });
</script>

<style>
  .site-header { position: absolute; inset: 0 0 auto; z-index: 50; padding: 1.1rem 1.5rem; }
  .header-inner { display: flex; align-items: center; justify-content: space-between; width: min(var(--page), 100%); min-height: 3rem; margin: 0 auto; }
  .brand { display: inline-flex; align-items: center; gap: 0.7rem; }
  .brand img { width: 2rem; height: 2rem; object-fit: contain; }
  .brand span { font-size: 1rem; font-weight: 720; }
  .desktop-nav, .desktop-actions { display: flex; align-items: center; }
  .desktop-nav { gap: clamp(1.35rem, 2.5vw, 2.2rem); }
  .desktop-nav a, .utility-link { color: rgba(247, 249, 251, 0.78); font-size: 0.87rem; font-weight: 520; transition: color 180ms ease; }
  .desktop-nav a:hover, .utility-link:hover { color: var(--white); }
  .desktop-actions { gap: 0.7rem; }
  .utility-link { display: inline-flex; align-items: center; gap: 0.45rem; }
  .utility-link svg, .icon-link svg, .menu-button svg { width: 1.1rem; height: 1.1rem; }
  .icon-link, .lang-switch, .menu-button { display: inline-flex; align-items: center; justify-content: center; height: 2.25rem; border: 1px solid rgba(255,255,255,0.16); border-radius: 5px; background: rgba(7,10,13,0.38); }
  .icon-link { width: 2.25rem; color: rgba(247,249,251,0.8); }
  .lang-switch { min-width: 2.25rem; padding: 0 0.55rem; font-size: 0.72rem; font-weight: 700; }
  .icon-link:hover, .lang-switch:hover, .menu-button:hover { border-color: rgba(112,214,163,0.55); color: var(--mint); }
  .mobile-actions { display: none; align-items: center; gap: 0.55rem; }
  .menu-button { width: 2.25rem; padding: 0; color: var(--white); cursor: pointer; }
  .mobile-menu { position: fixed; inset: 0; z-index: 80; display: flex; flex-direction: column; padding: 1.1rem 1.25rem 2rem; background: rgba(7,10,13,0.98); opacity: 0; pointer-events: none; transform: translateY(-0.5rem); transition: opacity 180ms ease, transform 180ms ease; }
  .mobile-menu.is-open { opacity: 1; pointer-events: auto; transform: none; }
  .mobile-menu-head { display: flex; align-items: center; justify-content: space-between; }
  .mobile-menu nav { display: flex; flex: 1; flex-direction: column; justify-content: center; gap: 1.35rem; }
  .mobile-menu nav a { padding-bottom: 0.65rem; border-bottom: 1px solid var(--line); font-size: clamp(1.5rem, 7vw, 2rem); font-weight: 620; }
  @media (max-width: 860px) { .desktop-nav, .desktop-actions { display: none; } .mobile-actions { display: flex; } }
  @media (max-width: 640px) { .site-header { padding-inline: 1rem; } }
</style>
