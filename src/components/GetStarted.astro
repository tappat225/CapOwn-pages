---
import { ArrowRight, BookOpen, GitFork } from '@lucide/astro';
import type { Lang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t(lang);
const docsUrl = lang === 'zh' ? 'https://docs.capown.net/zh/getting_started/' : 'https://docs.capown.net/getting_started/';
---

<section class="get-started" aria-labelledby="start-title">
  <div class="section-shell">
    <div class="section-heading">
      <p class="section-kicker">{i.start.kicker}</p>
      <h2 class="section-title" id="start-title">{i.start.title}</h2>
      <p class="section-description">{i.start.description}</p>
    </div>
    <ol class="start-steps">
      {i.start.steps.map((step) => (
        <li><span>{step.num}</span><div><h3>{step.title}</h3><p>{step.description}</p></div></li>
      ))}
    </ol>
    <div class="start-actions">
      <a class="button-link primary" href={docsUrl} target="_blank" rel="noreferrer"><BookOpen aria-hidden="true" />{i.start.cta_docs}<ArrowRight aria-hidden="true" /></a>
      <a class="button-link secondary" href="https://github.com/tappat225/CapOwn" target="_blank" rel="noreferrer"><GitFork aria-hidden="true" />{i.start.cta_github}</a>
      <a class="text-link" href="https://gitee.com/TappaT/CapOwn" target="_blank" rel="noreferrer">{i.start.cta_gitee}<ArrowRight aria-hidden="true" /></a>
    </div>
  </div>
</section>

<style>
  .get-started { padding: clamp(5rem, 10vw, 9rem) 0; background: var(--ink); }
  .get-started :global(.section-heading) { max-width: 820px; }
  .start-steps { display: grid; grid-template-columns: repeat(3, 1fr); margin: 0; padding: 0; border-block: 1px solid var(--line); list-style: none; }
  .start-steps li { display: grid; grid-template-columns: auto 1fr; gap: 1rem; min-width: 0; padding: 1.8rem clamp(1rem, 2.5vw, 2rem); border-right: 1px solid var(--line); }
  .start-steps li:first-child { padding-left: 0; }
  .start-steps li:last-child { padding-right: 0; border-right: 0; }
  .start-steps li > span { display: grid; width: 1.7rem; height: 1.7rem; place-items: center; border-radius: 50%; background: var(--mint); color: #07110c; font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700; }
  h3 { margin: 0; font-size: 1rem; font-weight: 640; }
  .start-steps p { margin: 0.5rem 0 0; color: var(--muted); font-size: 0.82rem; line-height: 1.62; }
  .start-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem; margin-top: 2.2rem; }
  .text-link { display: inline-flex; align-items: center; gap: 0.35rem; margin-left: 0.5rem; color: #9ba5ae; font-size: 0.8rem; }
  .text-link:hover { color: var(--white); }
  .text-link svg { width: 0.8rem; height: 0.8rem; }
  @media (max-width: 800px) {
    .start-steps { grid-template-columns: 1fr; }
    .start-steps li, .start-steps li:first-child, .start-steps li:last-child { padding: 1.4rem 0; border-right: 0; border-bottom: 1px solid var(--line); }
    .start-steps li:last-child { border-bottom: 0; }
  }
  @media (max-width: 520px) { .start-actions { flex-direction: column; align-items: stretch; } .text-link { justify-content: center; margin: 0.4rem 0 0; } }
</style>
