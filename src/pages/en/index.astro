---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Features from '../../components/Features.astro';
import Flow from '../../components/Flow.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en' as const;
---

<Base lang={lang} title="CapOwn | Agent-native remote execution" description="Let your AI Agent securely command remote machines through NAT — no inbound ports, no complex setup.">
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <Features lang={lang} />
    <Flow lang={lang} />
  </main>
  <Footer lang={lang} />
</Base>
